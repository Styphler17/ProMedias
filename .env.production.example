# Copy this to .env.production and fill in your real values before building.

# Full URL of your WordPress CMS on Hostinger (no trailing slash)
VITE_WC_URL=https://cms.yourdomain.com

# WooCommerce REST API keys — generate in WP Admin → WooCommerce → Settings → Advanced → REST API
VITE_WC_CONSUMER_KEY=ck_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_WC_CONSUMER_SECRET=cs_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
