# Copy to .env.local and fill in your values

# SQLite database file path (relative to cms/)
# Local dev: leave as default — creates promedias.db in the cms/ folder
# Production (VPS): use an absolute path, e.g. file:/var/www/cms/promedias.db
DATABASE_URI=file:./promedias.db

# Secret used to sign cookies — generate with: openssl rand -hex 32
PAYLOAD_SECRET=your-secret-key-here

# URL of this CMS server (no trailing slash)
NEXT_PUBLIC_SERVER_URL=http://localhost:3001

# URL of the React frontend (for CORS)
FRONTEND_URL=http://localhost:5173
