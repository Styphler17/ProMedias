# Copy to .env.local and fill in your values

# PostgreSQL connection string
# Local dev: install PostgreSQL locally OR use Neon dev branch URL
# Production: paste your Neon production connection string from neon.tech dashboard
DATABASE_URI=postgresql://user:password@localhost:5432/promedias_cms

# Secret used to sign cookies — generate with: openssl rand -hex 32
PAYLOAD_SECRET=your-secret-key-here

# URL of this CMS server (no trailing slash)
NEXT_PUBLIC_SERVER_URL=http://localhost:3001

# URL of the React frontend (for CORS)
FRONTEND_URL=http://localhost:5173
